{
  "name": "web-qiankun",
  "version": "1.0.0",
  "description": "qiankun框架",
  "main": "index.js",
  "scripts": {
    "install:vue2": "cd projects/vue2-app && npm install",
    "install:vue3": "cd projects/vue3-app && npm install",
    "install:main": "cd projects/main-app && npm install",
    "install:all": "npm-run-all --parallel install:main install:vue2 install:vue3",
    "start:main": "cd projects/main-app && npm run serve",
    "start:vue2": "cd projects/vue2-app && npm run serve",
    "start:vue3": "cd projects/vue3-app && npm run serve",
    "start:all": "sh -c \"npm run start:vue2 & npm run start:vue3 & until curl --silent --head --fail http://localhost:4001 >/dev/null 2>&1; do sleep 1; done; until curl --silent --head --fail http://localhost:4002 >/dev/null 2>&1; do sleep 1; done; npm run start:main\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Core10900/Web-Qiankun.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Core10900/Web-Qiankun/issues"
  },
  "homepage": "https://github.com/Core10900/Web-Qiankun#readme",
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node":"22.22.0",
    "npm":"10.9.4"
  }
}
